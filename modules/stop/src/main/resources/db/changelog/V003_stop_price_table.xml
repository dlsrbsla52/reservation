<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
>

  <!-- ============================================================
       V003-1. 정류소 단가 테이블 생성
       ============================================================ -->
  <changeSet id="V003-1" author="hig">

    <createTable tableName="stop_price" schemaName="stop"
                 remarks="정류소별 광고 단가 관리 테이블. 정류소당 단가 1건(1:1)을 보장한다.">

      <column name="id" type="UUID" remarks="단가 PK (UUID v7)">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="stop_id" type="UUID" remarks="정류소 PK 논리적 참조 (stop.stop.id, DB FK 미설정)">
        <constraints nullable="false" unique="true" uniqueConstraintName="uk_stop_price_stop_id"/>
      </column>

      <column name="unit_price" type="NUMERIC(15,2)" remarks="정류소 단가 (원)">
        <constraints nullable="false"/>
      </column>

      <column name="registered_by_id" type="UUID" remarks="등록한 관리자 회원 ID (auth.member.id 논리적 참조)"/>

      <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP" remarks="생성일시">
        <constraints nullable="false"/>
      </column>

      <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP" remarks="수정일시">
        <constraints nullable="false"/>
      </column>

    </createTable>

  </changeSet>

  <!-- ============================================================
       V003-2. 정류소 단가 변경 이력 테이블 생성
       ============================================================ -->
  <changeSet id="V003-2" author="hig">

    <createTable tableName="stop_price_history" schemaName="stop"
                 remarks="정류소 단가 등록/수정/삭제 이력 테이블 (append-only)">

      <column name="id" type="UUID" remarks="이력 PK (UUID v7)">
        <constraints primaryKey="true" nullable="false"/>
      </column>

      <column name="stop_id" type="UUID" remarks="변경 대상 정류소 PK 논리적 참조">
        <constraints nullable="false"/>
      </column>

      <column name="previous_price" type="NUMERIC(15,2)" remarks="변경 전 단가 (최초 등록 시 NULL)"/>
      <column name="new_price" type="NUMERIC(15,2)" remarks="변경 후 단가 (삭제 시 NULL)"/>

      <column name="change_type" type="VARCHAR(20)" remarks="변경 유형 [CREATE(등록), UPDATE(수정), DELETE(삭제)]">
        <constraints nullable="false"/>
      </column>

      <column name="changed_by_id" type="UUID" remarks="변경한 관리자 회원 ID (auth.member.id 논리적 참조)"/>

      <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
              defaultValueComputed="CURRENT_TIMESTAMP" remarks="이력 기록 일시">
        <constraints nullable="false"/>
      </column>

    </createTable>

    <createIndex indexName="idx_stop_price_history_stop_id"
                 tableName="stop_price_history" schemaName="stop">
      <column name="stop_id"/>
    </createIndex>

  </changeSet>

</databaseChangeLog>
