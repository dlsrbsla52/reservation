<?xml version="1.0" encoding="UTF-8"?>
<!--
  log4j2-spring.xml: Spring Boot가 자동으로 로드하는 Log4j2 설정 파일
  - AsyncRoot: LMAX Disruptor 기반 락프리(lock-free) 비동기 로깅 → Virtual Thread 핀닝 방지
  - local 프로파일: 컬러 패턴 로그 (가독성)
  - 그 외 환경:    JSON 구조화 로그 → AWS CloudWatch Logs Insights 쿼리 최적화

  MDC 필드:
    traceId   — Micrometer Tracing(OTel)이 자동 주입
    spanId    — Micrometer Tracing(OTel)이 자동 주입
    requestId — MdcLoggingFilter가 요청 단위로 주입 (X-Request-ID 헤더 또는 UUID)
    memberId    — MdcLoggingFilter가 인증된 사용자 Principal name 주입
    service   — spring.application.name 값
-->
<Configuration status="WARN">
    <SpringProperty name="appName" source="spring.application.name" defaultValue="bus"/>

    <Appenders>
        <!-- JSON 구조화 로그 (운영/스테이징 → CloudWatch) -->
        <Console name="JsonConsole" target="SYSTEM_OUT">
            <JsonTemplateLayout eventTemplateUri="classpath:logging/bus-log-template.json">
                <EventTemplateAdditionalField key="service" value="${appName}" format="STRING"/>
            </JsonTemplateLayout>
        </Console>

        <!-- 사람이 읽기 편한 컬러 로그 (local 개발) -->
        <Console name="PatternConsole" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss.SSS} %highlight{%-5level}{FATAL=red blink, ERROR=red, WARN=yellow, INFO=cyan, DEBUG=green, TRACE=white} [%t] [trace:%X{traceId} span:%X{spanId}] [req:%X{requestId}] [user:%X{memberId}] %cyan{%logger{36}} - %msg%n%throwable</Pattern>
            </PatternLayout>
        </Console>
    </Appenders>

    <Loggers>
        <AsyncRoot level="INFO" includeLocation="false">
            <SpringProfile name="local">
                <AppenderRef ref="PatternConsole"/>
            </SpringProfile>
            <SpringProfile name="!local">
                <AppenderRef ref="JsonConsole"/>
            </SpringProfile>
        </AsyncRoot>
    </Loggers>
</Configuration>
