<?xml version="1.0" encoding="UTF-8"?>
<!--
  log4j2-spring.xml: Spring Boot가 자동으로 로드하는 Log4j2 설정 파일
  - AsyncRoot: LMAX Disruptor 기반 락프리(lock-free) 비동기 로깅 → Virtual Thread 핀닝 방지
  - 모든 환경: 사람이 바로 읽을 수 있는 플레인 패턴 로그

  MDC 필드:
    requestId — MdcLoggingFilter가 요청 단위로 주입 (X-Request-ID 헤더 또는 UUID)
    memberId  — MdcLoggingFilter가 X-User-Id 헤더에서 주입
-->
<Configuration status="WARN">
    <Appenders>
        <!-- Docker logs에서도 바로 읽을 수 있는 콘솔 패턴 -->
        <Console name="PatternConsole" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] [req:%X{requestId}] [user:%X{memberId}] %logger{36} - %msg%n%throwable</Pattern>
            </PatternLayout>
        </Console>
    </Appenders>

    <Loggers>
        <AsyncRoot level="INFO" includeLocation="false">
            <AppenderRef ref="PatternConsole"/>
        </AsyncRoot>
    </Loggers>
</Configuration>
